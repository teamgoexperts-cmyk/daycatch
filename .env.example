# Copy to .env and edit. .env is gitignored.

# --- Database (Railway) ---
# Local dev: set DATABASE_PUBLIC_URL (proxy host). On Railway, DATABASE_URL
# (internal) is injected automatically — database.py falls back to public when
# the internal host is unreachable from your machine.
DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@hayabusa.proxy.rlwy.net:12043/railway
DATABASE_URL=postgresql://postgres:PASSWORD@hayabusa.proxy.rlwy.net:12043/railway

# --- Session JWT ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=12

# --- Phone OTP (backend-managed, stored in Postgres) ---
# Dev: log OTP to console and return in API response (no SMS provider).
DEV_LOG_OTP=true
OTP_TTL_MINUTES=10

# --- CORS ---
# Also allow https://*.daycatch.in via allow_origin_regex in app.py.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://daycatch.in,https://www.daycatch.in,http://localhost:8000,http://localhost:8081,http://127.0.0.1:8081

# --- Seed users on first run (E.164 +91, or 10 digits which auto-prefix) ---
ADMIN_PHONES=+919999999999
DISTRIBUTOR_PHONES=
KIOSK_PHONES=

# --- Razorpay payments ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
